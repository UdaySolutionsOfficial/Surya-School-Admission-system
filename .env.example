# Server Settings
PORT=3000

# Set to true to bypass Google Sheets & Email API calls for local testing
MOCK_MODE=true

# Google Sheets Configuration
# Share the Google Sheet with this service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Use double quotes for the private key to handle newlines correctly
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# SMTP / Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# School Notification Recipient
SCHOOL_EMAIL=admissions@suryaschool.edu.in
PRINCIPAL_CONTACT=8813256157
